# URL base de la API de NestJS (incluye el prefijo /api).
VITE_API_URL="http://localhost:3000/api"

# ───────── Clerk (autenticación) ─────────
# Publishable key de Clerk (Dashboard -> API Keys, empieza con pk_test_ / pk_live_).
# - Si la completás: la app exige login (toda la app queda protegida).
# - Si la dejás vacía: la app corre SIN auth (modo dev). En ese caso, el backend
#   debe tener AUTH_DISABLED="true".
VITE_CLERK_PUBLISHABLE_KEY=""
